{
  "name": "Post",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Title of the post"
    },
    "description": {
      "type": "string",
      "description": "Description of the post"
    },
    "theme": {
      "type": "string",
      "enum": [
        "live",
        "video",
        "short",
        "event",
        "game",
        "creation",
        "invite",
        "other"
      ],
      "description": "Theme/category of the post"
    },
    "image_url": {
      "type": "string",
      "description": "Optional image URL"
    },
    "youtube_url": {
      "type": "string",
      "description": "Optional YouTube video URL"
    },
    "timer_type": {
      "type": "string",
      "enum": [
        "none",
        "countdown",
        "remaining"
      ],
      "default": "none",
      "description": "Type of timer"
    },
    "timer_date": {
      "type": "string",
      "format": "date-time",
      "description": "Date for countdown/remaining timer"
    },
    "scheduled_date": {
      "type": "string",
      "format": "date-time",
      "description": "If scheduled, when to publish"
    },
    "is_published": {
      "type": "boolean",
      "default": true
    },
    "notify_users": {
      "type": "boolean",
      "default": false
    },
    "likes_count": {
      "type": "number",
      "default": 0
    },
    "liked_by": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Array of user emails who liked the post"
    }
  },
  "required": [
    "title",
    "theme"
  ]
}